# Optional: force the desktop app to use a specific SkillTree data folder.
SKILLTREE_STORAGE_ROOT="/absolute/path/to/SkillTree"

# Optional: use an Obsidian vault as the desktop app storage backend.
OBSIDIAN_VAULT_PATH="/absolute/path/to/your/ObsidianVault"
SKILLTREE_OBSIDIAN_ROOT="SkillTree"

# Optional: disable startup GitHub Release update checks.
SKILLTREE_DISABLE_AUTO_UPDATE=1

# Optional: avoid GitHub API rate limits during update checks.
GITHUB_TOKEN=""

# Legacy web app variables are intentionally omitted because the Rust desktop app is primary.
